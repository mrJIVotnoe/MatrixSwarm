# MatrixSwarm Configuration
# Copy this file to .env and adjust values

# Ports
PORT=3000

# Security
SECRET_KEY=your-super-secret-key-change-this
MATRIX_SERVER_NAME=swarm.local
REGISTRATION_TOKEN=your-registration-token

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/matrixswarm

# Flask
FLASK_ENV=production
FLASK_DEBUG=0

# TOR (optional)
ENABLE_TOR=false
TOR_SOCKS_PORT=9050

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/matrixswarm.log

# Resource Limits
MAX_TASKS_PER_NODE=10
MAX_MEMORY_MB=512
CPU_LIMIT=0.8

# Matrix Control Plane Configuration (For matrix_agent.ts)
MATRIX_HOMESERVER_URL=https://matrix.org
MATRIX_ACCESS_TOKEN=your_matrix_access_token_here
MATRIX_USER_ID=@your_bot_user:matrix.org
MATRIX_ROOM_ID=!your_room_id:matrix.org
